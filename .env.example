# ── POS Integration ─────────────────────────────────────────
POS_STREAM_URL=ws://localhost:9000/orders
POS_API_KEY=your_pos_api_key_here

# ── App mode ────────────────────────────────────────────────
# Set DEMO_MODE=true to run with synthetic orders (no POS needed)
DEMO_MODE=true

# ── Rush hour window ────────────────────────────────────────
RUSH_HOUR_START=07:45
RUSH_HOUR_END=09:15
ORDERS_PER_MIN_RUSH_THRESHOLD=6

# ── Machine calibration (seconds) ───────────────────────────
GROUP1_SHOT_TIME=28
GROUP2_SHOT_TIME=27
STEAMER_WARMUP_TIME=8
GRINDER_TIME=10
ASSEMBLE_TIME=15

# ── Milk steam times (seconds) ──────────────────────────────
MILK_WHOLE_STEAM=24
MILK_OAT_STEAM=32
MILK_ALMOND_STEAM=30
MILK_SOY_STEAM=28
MILK_COCONUT_STEAM=30

# ── Scheduler ───────────────────────────────────────────────
MAX_CONCURRENT_SLOTS=3
WAIT_TIME_WEIGHT=0.70
COMPLEXITY_WEIGHT=0.20
MACHINE_FIT_WEIGHT=0.10

# ── RL Training ─────────────────────────────────────────────
RL_LIVE_TRAINING=true
RL_LEARNING_RATE=0.03
RL_DISCOUNT_FACTOR=0.95
RL_EPSILON=0.12
RL_CHECKPOINT_PATH=data/models/rl_policy.pkl

# ── API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_in_production

# ── Weather API (optional, for demand forecasting) ──────────
OPENWEATHER_API_KEY=
CAFE_LAT=19.0760
CAFE_LNG=72.8777
